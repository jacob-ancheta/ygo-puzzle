def decode_place_flag(flag, playerid):
    # bit layout per ygopro-core playerop.cpp field::select_place (bit set = zone blocked):
    #   0-6: own mzone seq 0-6      8-12: own szone seq 0-4      14-15: own pzone (seq 6/7)
    #   16-22: opp mzone seq 0-6    24-28: opp szone seq 0-4     30-31: opp pzone (seq 6/7)
    opp = 1 - playerid
    options = []
    for s in range(7):
        if not (flag & (1 << s)):
            options.append((playerid, LOCATION_MZONE, s, f"Your Monster Zone {s}"))
    for s in range(5):
        if not (flag & (1 << (8 + s))):
            options.append((playerid, LOCATION_SZONE, s, f"Your Spell/Trap Zone {s}"))
    if not (flag & (1 << 14)):
        options.append((playerid, LOCATION_SZONE, 6, "Your Pendulum Zone (left)"))
    if not (flag & (1 << 15)):
        options.append((playerid, LOCATION_SZONE, 7, "Your Pendulum Zone (right)"))
    for s in range(7):
        if not (flag & (1 << (16 + s))):
            options.append((opp, LOCATION_MZONE, s, f"Opponent Monster Zone {s}"))
    for s in range(5):
        if not (flag & (1 << (24 + s))):
            options.append((opp, LOCATION_SZONE, s, f"Opponent Spell/Trap Zone {s}"))
    if not (flag & (1 << 30)):
        options.append((opp, LOCATION_SZONE, 6, "Opponent Pendulum Zone (left)"))
    if not (flag & (1 << 31)):
        options.append((opp, LOCATION_SZONE, 7, "Opponent Pendulum Zone (right)"))
    return options

def prompt_choice(n, label="choice"):
    while True:
        raw = input(f"  enter {label} (0-{n-1}): ").strip()
        if raw.isdigit() and 0 <= int(raw) < n:
            return int(raw)
        print("  invalid input, try again")


class DuelEnded(Exception):
    """Raised when the engine's processor queue is genuinely empty (no more
    messages will ever come without some external stimulus we haven't given)."""

# ---------- message stream: pulls from the engine, transparently spanning
# multiple process() calls so a single message is never split ----------
class MessageStream:
    def __init__(self):
        self.buf = b""
        self.pos = 0

    def _refill(self):
        # A single process() call can legitimately come back with nothing new
        # (the engine's internal step queue can go quiet for a call or two,
        # e.g. right after a PROCESSOR_WAIT-based message like MSG_CONFIRM_CARDS,
        # while it resumes the yielded script) without the duel actually being
        # over, so retry a bounded number of times before giving up for real.
        for _ in range(1000):
            result = lib.process(ctypes.c_ssize_t(pduel))
            msg_len = result & 0xffff
            if msg_len:
                raw = (ctypes.c_ubyte * msg_len)()
                lib.get_message(ctypes.c_ssize_t(pduel), raw)
                self.buf = bytes(raw)
                self.pos = 0
                return True
        return False

    def _ensure(self):
        while self.pos >= len(self.buf):
            if not self._refill():
                raise DuelEnded()

    def u8(self):
        self._ensure()
        v = self.buf[self.pos]; self.pos += 1
        return v

    def u16(self):
        self._ensure()
        v = int.from_bytes(self.buf[self.pos:self.pos + 2], "little"); self.pos += 2
        return v

    def u32(self):
        self._ensure()
        v = int.from_bytes(self.buf[self.pos:self.pos + 4], "little"); self.pos += 4
        return v

    def raw(self, n):
        self._ensure()
        v = self.buf[self.pos:self.pos + n]; self.pos += n
        return v

stream = MessageStream()

def send_i(value):
    lib.set_responsei(ctypes.c_ssize_t(pduel), ctypes.c_int32(value))

def send_b(byte_values):
    # set_responseb always memcpy's a fixed 256 bytes from whatever we pass,
    # so the buffer must always be fully allocated, not sized to the payload.
    buf_out = (ctypes.c_ubyte * 256)()
    for i, v in enumerate(byte_values):
        buf_out[i] = v & 0xff
    lib.set_responseb(ctypes.c_ssize_t(pduel), buf_out)

def interact(ask):
    """Run `ask()` (which reads a decision and submits a response), and if the
    engine rejects it with MSG_RETRY, print a note and just ask again -- the
    same prompt, not a crash. Returns the next non-retry message type."""
    while True:
        ask()
        msg = stream.u8()
        if msg == MSG_RETRY:
            print("  (that wasn't a legal choice for this decision -- try again)")
            continue
        return msg

def read_zone_card_list(n, extra_u32=False):
    """Reads n * (code:u32, controller:u8, location:u8, sequence:u8[, extra:u32])."""
    items = []
    for _ in range(n):
        code = stream.u32() & 0x7fffffff
        ctrl = stream.u8(); loc = stream.u8(); seq = stream.u8()
        extra = stream.u32() if extra_u32 else None
        items.append((code, ctrl, loc, seq, extra))
    return items

def prompt_card_selection(items, min_sel, max_sel):
    """Generic 'pick between min_sel and max_sel cards from a list' UI,
    shared by MSG_SELECT_CARD / MSG_SELECT_TRIBUTE / MSG_SELECT_SUM etc.
    Returns the list of chosen indices."""
    for i, code in enumerate(items):
        print(f"  {i}: {card_name(code)}")
    chosen = []
    while len(chosen) < max_sel:
        if len(chosen) >= min_sel:
            raw = input("  enter index to add (or blank to finish): ").strip()
            if raw == "":
                break
            if not raw.isdigit() or not (0 <= int(raw) < len(items)) or int(raw) in chosen:
                print("  invalid"); continue
            chosen.append(int(raw))
        else:
            idx = prompt_choice(len(items), f"card {len(chosen) + 1}/{min_sel}")
            if idx in chosen:
                print("  already chosen"); continue
            chosen.append(idx)
    return chosen


PHASE_END = 0x200

def run():
    pending = None
    current_turn_player = 0
    while True:
        msg = pending if pending is not None else stream.u8()
        pending = None

        if msg == MSG_NEW_TURN:
            player = stream.u8()
            current_turn_player = player
            print(f"\n=== Turn: player {player} {'(you)' if player == 0 else '(opponent)'} ===")

        elif msg == MSG_NEW_PHASE:
            phase = stream.u16()
            print(f"--- {PHASE_NAMES.get(phase, hex(phase))} ---")
            if phase == PHASE_END and current_turn_player == 0:
                print("\n*** LOSS: turn ended without winning -- puzzle not solved ***")
                return

        elif msg == MSG_HINT:
            stream.u8()   # hint type (event/message/selectmsg/etc.)
            stream.u8()   # player
            stream.u32()  # value
            # purely a UI hint, nothing to display or act on

        elif msg == MSG_DRAW:
            player = stream.u8()
            count = stream.u8()
            codes = [stream.u32() & 0x7fffffff for _ in range(count)]
            who = "You" if player == 0 else "Opponent"
            print(f"{who} drew {count} card(s): {', '.join(card_name(c) for c in codes)}")

        elif msg == MSG_MOVE:
            code = stream.u32() & 0x7fffffff
            prev = stream.u32()
            cur = stream.u32()
            stream.u32()  # reason, not needed for display
            print(f"{card_name(code)} moved: {describe_location(prev)} -> {describe_location(cur)}")

        elif msg == MSG_SUMMONING:
            code = stream.u32() & 0x7fffffff
            stream.u32()  # location info, redundant with the MSG_MOVE just printed
            print(f"Summoning {card_name(code)}...")

        elif msg == MSG_SUMMONED:
            print("...summon resolved.")

        elif msg == MSG_SPSUMMONING:
            code = stream.u32() & 0x7fffffff
            stream.u32()
            print(f"Special summoning {card_name(code)}...")

        elif msg == MSG_SPSUMMONED:
            print("...special summon resolved.")

        elif msg == MSG_FLIPSUMMONING:
            code = stream.u32() & 0x7fffffff
            stream.u32()
            print(f"Flip summoning {card_name(code)}...")

        elif msg == MSG_FLIPSUMMONED:
            print("...flip summon resolved.")

        elif msg == MSG_CHAINING:
            code = stream.u32() & 0x7fffffff
            stream.u32()  # location info
            stream.u8(); stream.u8(); stream.u8()  # controller, location, sequence
            desc = stream.u32()
            chain_size = stream.u8()
            print(f"Activating {card_name(code)} (chain link {chain_size}, desc {desc})")

        elif msg == MSG_CHAINED:
            stream.u8()  # chain_count, UI-only

        elif msg == MSG_CHAIN_SOLVING:
            n = stream.u8()
            print(f"Resolving chain link {n}...")

        elif msg == MSG_CHAIN_SOLVED:
            stream.u8()

        elif msg == MSG_CHAIN_END:
            print("Chain fully resolved.")

        elif msg == MSG_CHAIN_NEGATED:
            n = stream.u8()
            print(f"Chain link {n} was negated.")

        elif msg == MSG_CHAIN_DISABLED:
            n = stream.u8()
            print(f"Chain link {n} was disabled.")

        elif msg == MSG_SHUFFLE_DECK:
            player = stream.u8()
            print(f"(deck reshuffled for player {player})")

        elif msg == MSG_SHUFFLE_HAND:
            player = stream.u8()
