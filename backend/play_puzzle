def resolve_all(puzzle):
    names = [e["name"] for e in puzzle["opponent_field"]]
    names += puzzle["player_hand"] + puzzle["player_deck"] + puzzle["player_extra"]
    resolved, failed = {}, []
    for name in names:
        card = get_card_by_name(name)
        if card is None:
            failed.append(name)
        else:
            resolved[name] = card
    if failed:
        for name in failed:
            print(f"'{name}' not found. Close matches:")
            for code, cname, *_ in search_cards(name, limit=5):
                print(f"    {code:>10}  {cname}")
        raise SystemExit(1)
    return resolved

