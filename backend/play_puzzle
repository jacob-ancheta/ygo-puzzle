def describe_location(info):
    controller = info & 0xff
    location = (info >> 8) & 0xff
    sequence = (info >> 16) & 0xff
    who = "your" if controller == 0 else "opponent's"
    loc_name = LOCATION_NAMES.get(location, hex(location))
    if location in (LOCATION_MZONE, LOCATION_SZONE):
        return f"{who} {loc_name} {sequence}"
    return f"{who} {loc_name}"

