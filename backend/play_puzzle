                            break
                        if raw.lstrip("-").isdigit() and 0 <= int(raw) < len(chains):
                            choice = int(raw)
                            break
                        print("  invalid input, try again")
                    send_i(choice)
                pending = interact(ask)
            elif chains and player != 1:
                def ask():
                    print(f"\n[player {player}] Chain window -- activate an effect?")
                    for i, (forced, code, desc) in enumerate(chains):
